  "keyFeatures": [
    "Multi-language SDKs (Python, JavaScript, Kotlin, C#)",
    "Docker and Kubernetes runtime support",
    "Code Interpreter with Jupyter integration",
    "File system operations and command execution",
    "Network ingress/egress controls",
    "Resource pooling and batch sandbox creation",
    "Browser automation and desktop environments",
    "AI coding agent integrations"
  ],
  "publicApiSurface": [
    "Sandbox.create() - Create sandbox instances",
    "sandbox.commands.run() - Execute shell commands",
    "sandbox.files.write_file() - Write files to sandbox",
    "sandbox.files.read_file() - Read files from sandbox",
    "CodeInterpreter.create() - Create code execution contexts",
    "interpreter.codes.run() - Execute code in multiple languages",
    "sandbox.pause() - Pause sandbox execution",
    "sandbox.resume() - Resume paused sandbox",
    "sandbox.renew_expiration() - Extend sandbox lifetime",
    "sandbox.get_endpoint() - Get public endpoint for sandbox ports",
    "POST /v1/sandboxes - Lifecycle API: Create sandbox",
    "GET /v1/sandboxes/{id} - Lifecycle API: Get sandbox details",
    "DELETE /v1/sandboxes/{id} - Lifecycle API: Delete sandbox",
    "POST /code - Execution API: Execute code",
    "POST /command - Execution API: Run shell command",
    "POST /files/upload - Execution API: Upload files",
    "GET /files/download - Execution API: Download files",
    "GET /metrics/watch - Execution API: Stream system metrics"
  ]
